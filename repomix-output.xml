  </div>

  {/* Bottom Controls: Input aur Dashboard Label */}
  <div className="w-full space-y-4 pb-4 bg-black/80 backdrop-blur-md">
    <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} className="relative group">
      <div className="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-purple-600 rounded-2xl blur opacity-20"></div>
      <div className="relative bg-black/60 border border-white/10 backdrop-blur-xl rounded-2xl p-1 flex items-center">
        <input 
          type="text" 
          value={userInput}
          onChange={(e) => setUserInput(e.target.value)}
          onKeyDown={(e) => e.key === 'Enter' && handleDashSend()}
          placeholder="Ask AF Infinity..."
          className="bg-transparent w-full p-4 text-white outline-none font-mono text-sm"
        />
        <button onClick={handleDashSend} className="p-3 text-cyan-400 hover:scale-110 transition-transform">
          <Zap size={20} />
        </button>
      </div>
    </motion.div>
    
    {/* Ye hissa ab chat ke dabao mein nahi aayega */}
    <div className="flex flex-col items-center text-gray-600 py-2">
      <span className="text-[9px] font-mono tracking-[0.2em] uppercase opacity-50">SYSTEM_DASHBOARD</span>
      <ChevronDown size={14} className="animate-bounce mt-1 opacity-50" />
    </div>
  </div>
</section>


      {/* SECTION 2: COMMAND CENTER TILES */}
      <section className="min-h-screen p-4 space-y-4 snap-start bg-black">

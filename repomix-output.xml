<file path="src/components/layout/PasscodeModal.tsx">
import { motion } from 'framer-motion';
import { Shield, Lock } from 'lucide-react';
import { Modal } from '../ui/Modal';
import { useApp } from '../../context/AppContext';
import { useSecretAccess } from '../../hooks/useSecretAccess';

export function PasscodeModal() {
  const { showPasscodeModal, themeColor } = useApp();
  const { passcode, setPasscode, error, shake, verifyPasscode, closeModal } = useSecretAccess();

  const handleKey = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter') verifyPasscode();
  };

  return (
    <Modal open={showPasscodeModal} onClose={closeModal}>
      <div className="text-center space-y-6">
        <div className="flex justify-center">
          <motion.div
            className="w-16 h-16 rounded-2xl flex items-center justify-center"
            style={{ background: `${themeColor}22`, border: `1px solid ${themeColor}44` }}
            animate={{ boxShadow: [`0 0 0px ${themeColor}`, `0 0 20px ${themeColor}88`, `0 0 0px ${themeColor}`] }}
            transition={{ duration: 2, repeat: Infinity }}
          >
            <Shield size={28} style={{ color: themeColor }} />
          </motion.div>
        </div>

        <div>
          <h3 className="text-xl font-bold text-white tracking-wide">MASTER CONTROL</h3>
          <p className="text-xs text-gray-400 mt-1 font-mono">ENTER SECURITY PASSCODE</p>
        </div>

        <motion.div
          animate={shake ? { x: [-8, 8, -8, 8, 0] } : {}}
          transition={{ duration: 0.3 }}
        >
          <div className="relative">
            <Lock size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500" />
            <input
              type="password"
              value={passcode}
              onChange={e => setPasscode(e.target.value)}
              onKeyDown={handleKey}
              maxLength={8}
              placeholder="••••"
              className="w-full bg-white/5 border border-white/20 rounded-xl pl-9 pr-4 py-3 text-center text-white text-xl tracking-[0.5em] font-mono focus:outline-none transition-colors"
              style={{ caretColor: themeColor }}
              onFocus={e => (e.target.style.borderColor = `${themeColor}66`)}
              onBlur={e => (e.target.style.borderColor = 'rgba(255,255,255,0.2)')}
              autoFocus
            />
          </div>
          {error && (
            <motion.p
              className="text-xs font-mono mt-2"
              style={{ color: '#ff3366' }}
              initial={{ opacity: 0, y: -4 }}
              animate={{ opacity: 1, y: 0 }}
            >
              {error}
            </motion.p>
          )}
        </motion.div>

        <div className="flex gap-3">
          <button
            onClick={closeModal}
            className="flex-1 py-2.5 rounded-xl border border-white/20 text-gray-400 hover:text-white hover:bg-white/5 transition-all text-sm font-medium"
          >
            Cancel
          </button>
          <button
            onClick={verifyPasscode}
            className="flex-1 py-2.5 rounded-xl font-medium text-sm transition-all text-white"
            style={{ background: `linear-gradient(135deg, ${themeColor}cc, ${themeColor}88)` }}
          >
            ACCESS
          </button>
        </div>
      </div>
    </Modal>
  );
}
</file>

